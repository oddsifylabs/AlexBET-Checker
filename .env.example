# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Optional: The Odds API key for CLV (Closing Line Value) checks
# Get one at https://the-odds-api.com/
# ODDS_API_KEY=your_key_here

# Optional: ESPN API timeout in seconds (default: 10)
# ESPN_TIMEOUT=10

# Optional: Max requests per user per minute (default: 10)
# MAX_REQUESTS_PER_MINUTE=10

# Optional: Log level — DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
